# Argus environment variables
# Copy to .env to override any of these. All are optional — the app runs without this file.

# Session signing key. Auto-generated on first startup if not set.
# Override here if you want a stable key across reinstalls or multiple instances.
# SECRET_KEY=

# Override default paths (rarely needed)
# DB_PATH=data/argus.db
# DATA_PATH=data
# MODELS_PATH=models
